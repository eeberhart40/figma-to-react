# Required
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional — enables Figma MCP server as a richer spec source
# Create an OAuth app at https://www.figma.com/developers/apps
# Set redirect URI to: http://localhost:7895/callback
# Enable scopes: mcp:connect, file_read
FIGMA_CLIENT_ID=your_figma_client_id

# Auto-populated after first OAuth login — do not edit manually
# FIGMA_OAUTH_TOKEN=
# FIGMA_OAUTH_REFRESH_TOKEN=
